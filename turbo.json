{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*",
        "env:FRONTEND_URL",
        "env:POSTGRES_USER",
        "env:POSTGRES_PASSWORD",
        "env:POSTGRES_DB",
        "env:POSTGRES_PORT",
        "env:PGADMIN_EMAIL",
        "env:PGADMIN_PASSWORD",
        "env:PGADMIN_PORT",
        "env:MASTER_PASSWORD",
        "env:DATABASE_URL",
        "env:BETTER_AUTH_SECRET",
        "env:BETTER_AUTH_URL"
      ],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
