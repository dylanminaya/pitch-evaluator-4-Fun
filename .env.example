# Database Configuration
POSTGRES_USER=pitch
POSTGRES_PASSWORD=pitch_secret
POSTGRES_DB=pitch_evaluator
POSTGRES_PORT=5432

# Connection string for your app
DATABASE_URL=postgresql://pitch:pitch_secret@localhost:5432/pitch_evaluator

# pgAdmin (Database UI)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-change-in-production
BETTER_AUTH_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Resend
RESEND_API_KEY=re_your_resend_api_key
# Must use a sender from a domain verified in Resend, e.g. invitations@yourdomain.com.
EMAIL_FROM=onboarding@resend.dev


# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3001
